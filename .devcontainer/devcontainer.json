{
  "name": "pywidget",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-python.python"
      ],
      "settings": {
        "jupyter.widgetScriptSources": ["jsdelivr.com", "unpkg.com"]
      }
    }
  },
  "onCreateCommand": "pip install -e '.[dev]'",
  "waitFor": "onCreateCommand"
}
